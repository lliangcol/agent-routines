  "properties": {
    "ok": { "type": "boolean" },
    "workflow": { "type": "string" },
    "cwd": { "type": "string" },
    "os": { "type": "string" },
    "checks": { "type": "array" },
    "warnings": { "type": "array" },
    "errors": { "type": "array" }
  },
  "additionalProperties": true
}
